rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profile document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Subcollections owned by the user (e.g., weights)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Top-level meals collection: only allow access to a user's own docs
    match /meals/{mealId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Top-level custom meals collection: only allow access to a user's own docs
    match /custom_meals/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}


